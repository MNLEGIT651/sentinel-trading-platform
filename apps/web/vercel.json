{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "turbo run build --filter=@sentinel/web",
  "ignoreCommand": "bash scripts/vercel-ignore-command.sh",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/internal/cron/health",
      "schedule": "*/5 * * * *"
    }
  ]
}
