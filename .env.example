# ─── Sentinel Trading Platform ─── Environment Variables ───────────────────
# Copy this file to .env and fill in your credentials.
# Required variables are marked with [REQUIRED].

# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=             # [REQUIRED] e.g. https://abc123.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # [REQUIRED] public anon key
SUPABASE_SERVICE_ROLE_KEY=            # [REQUIRED] service role key (never expose client-side)

# ─── Polygon.io (Market Data) ─────────────────────────────────────────────
# Get from: https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=                      # [REQUIRED] free tier: 5 req/min

# ─── Alpaca (Broker) ──────────────────────────────────────────────────────
# Get from: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=                       # [REQUIRED] paper trading key
ALPACA_SECRET_KEY=                    # [REQUIRED] paper trading secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper trading endpoint
BROKER_MODE=paper                     # paper | live (use paper for development)

# ─── Anthropic (AI Agents) ────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=                    # [REQUIRED] for agent orchestrator

# ─── Engine ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000   # quant engine URL
ENGINE_API_KEY=sentinel-dev-key               # internal API key
NEXT_PUBLIC_ENGINE_API_KEY=sentinel-dev-key   # client-side engine API key (same as ENGINE_API_KEY)
CORS_ORIGINS=http://localhost:3000            # allowed CORS origins

# ─── Agents ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENTS_URL=http://localhost:3001   # agent orchestrator URL
AGENTS_PORT=3001                              # agents server port

# ─── Scheduling (Engine) ──────────────────────────────────────────────────
DATA_INGESTION_INTERVAL_MINUTES=1440          # daily data refresh
SIGNAL_GENERATION_INTERVAL_MINUTES=15         # signal scan frequency
RISK_UPDATE_INTERVAL_MINUTES=5                # risk metric refresh
