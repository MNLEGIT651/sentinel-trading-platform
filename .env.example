# ═══════════════════════════════════════════════════════════════════════════════
# Sentinel Trading Platform — environment template
# ═══════════════════════════════════════════════════════════════════════════════
#
# How teams usually manage this in a monorepo:
#   • Keep ONE real secrets file at the repo root: `.env` (gitignored).
#   • Copy this file to `.env` and fill values. Never commit `.env`.
#   • Engine reads root `.env` via pydantic (start engine from `apps/engine/`).
#   • Agents load root `.env` automatically (see `apps/agents/src/index.ts`).
#   • Next.js merges `apps/web/.env.local` on top; `next.config.ts` also loads root
#     `.env` first so local dev can use a single file. Vercel: use Dashboard or
#     `vercel env pull apps/web/.env.local` for preview/production.
#
# Legend:  [web] [engine] [agents] = which runtime reads the variable (some overlap).
#          REQUIRED / OPTIONAL / RECOMMENDED = for a full local stack.
#
# Validate:  pnpm env:check
#            python .claude/skills/sentinel-env-check/scripts/check-env.py
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project → Settings → API
# [web] Browser + server; [engine] [agents] server-side PostgREST
NEXT_PUBLIC_SUPABASE_URL=
# [web] At least ONE client key (priority: top → bottom in code):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# [web] Admin client (API routes, webhooks). [engine] [agents] DB access
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# [agents] JWT verification for authenticated requests to agents API
SUPABASE_JWT_SECRET=

# ─── Site URL (auth redirects, sitemap) ─────────────────────────────────────
# [web] Production: set to your canonical URL. Vercel sets NEXT_PUBLIC_VERCEL_URL.
NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_VERCEL_URL=   # set by Vercel; optional override for previews

# ─── Anthropic (LLM) ─────────────────────────────────────────────────────────
# [agents] REQUIRED for orchestrator — console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Internal services (web proxies → engine/agents on the server) ───────────
# [web] [engine] [agents] ENGINE_API_KEY must match everywhere.
ENGINE_URL=http://localhost:8000
ENGINE_API_KEY=
# [web] Recommended when dashboard talks to agents
AGENTS_URL=http://localhost:3001
# [web] Optional Bearer for web → agents (when agents enforce it)
AGENTS_API_KEY=
# [agents] HTTP listen port (Railway sets PORT)
AGENTS_PORT=3001
# PORT=
# [agents] CORS allowed browser origin
WEB_URL=http://localhost:3000

# ─── Engine market data & broker ────────────────────────────────────────────
# [engine] REQUIRED for live market data (quotes, bars, scanning)
POLYGON_API_KEY=
# [engine] REQUIRED for live or paper trading via Alpaca
#   When BROKER_MODE=live these are mandatory; engine will refuse to start without them.
#   When BROKER_MODE=paper these are recommended (enables Alpaca paper trading);
#   without them the in-memory PaperBroker is used instead.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# [engine] Must be https://api.alpaca.markets for BROKER_MODE=live
#   Default (paper-api) is correct for BROKER_MODE=paper
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# [engine] Broker mode: 'paper' (default, safe) or 'live' (real money)
#   Switching to 'live' requires valid ALPACA credentials and the live base URL.
BROKER_MODE=paper
# [engine] CORS for browser → engine (local dev)
CORS_ORIGINS=http://localhost:3000
# [engine] Optional experiment tag
EXPERIMENT_ID=

# ─── Alpaca Broker API (onboarding / KYC) ─────────────────────────────────────
# [engine] Optional — app.alpaca.markets brokerage dashboard
ALPACA_BROKER_API_KEY=
ALPACA_BROKER_API_SECRET=
ALPACA_BROKER_API_URL=https://broker-api.sandbox.alpaca.markets

# ─── Plaid (portfolio linking) ────────────────────────────────────────────────
# [web] — dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ─── Webhooks & cron ──────────────────────────────────────────────────────────
# [web] Alpaca activity webhooks — configure same secret in Alpaca dashboard
ALPACA_WEBHOOK_SECRET=
# [web] Bearer for /api/internal/cron/* (set in Vercel Cron + Production)
CRON_SECRET=

# ─── Agent auto-execution tuning ─────────────────────────────────────────────
# [agents] Safe defaults if omitted
AUTO_EXEC_SIGNAL_THRESHOLD=0.7
AUTO_EXEC_DAILY_LIMIT=10
AUTO_EXEC_MAX_POSITION_VALUE=50000

# ─── Agent / WAT runtime ─────────────────────────────────────────────────────
WORKFLOW_JOB_TIMEOUT_SECONDS=300
PYTHON_PATH=python
# [agents] WAT self-improve git features (default on)
# WAT_SELF_IMPROVE_GIT=true

# ─── Engine process tuning ───────────────────────────────────────────────────
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=100

# ─── Observability (all services, opt-in) ───────────────────────────────────────
# RECOMMENDED for production — set OTEL_ENABLED=true for distributed tracing
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=https://…   # engine + Node apps when OTLP export on

# ─── Web-only extras ──────────────────────────────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_APP_VERSION=   # optional display string
# STANDALONE_BUILD=1           # Docker / non-Vercel Next standalone output
# ANALYZE=true                 # bundle analyzer

# ─── E2E / Playwright (never enable in production) ──────────────────────────
# E2E_AUTH_BYPASS=1
# BASE_URL=http://localhost:3000

# ─── Platform-injected (do not copy into Vercel Dashboard manually) ─────────
# VERCEL=1
# VERCEL_ENV=production|preview|development
# VERCEL_OIDC_TOKEN=…          # short-lived; added by `vercel dev` / CLI — never commit
