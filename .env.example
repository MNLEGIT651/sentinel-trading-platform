# ─── Sentinel Trading Platform ─── Environment Variables ───────────────────
# Copy this file to .env and fill in your credentials.
# Required variables are marked with [REQUIRED]. Optional ones with [OPTIONAL].

# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=             # [REQUIRED] e.g. https://abc123.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=  # [REQUIRED] modern publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # [FALLBACK] legacy anon key (used if publishable key is not set)
SUPABASE_URL=                         # [REQUIRED] same project URL, server-side for engine/agents
SUPABASE_SERVICE_ROLE_KEY=            # [REQUIRED] service role key (never expose client-side)
SUPABASE_JWT_SECRET=                  # [REQUIRED for agents auth] JWT secret from Supabase Dashboard → Settings → API

# ─── Site URL (Auth Redirects) ────────────────────────────────────────────
# Canonical URL for email confirmation and password reset links.
# In Vercel deployments, NEXT_PUBLIC_VERCEL_URL is auto-set as a fallback.
# Locally defaults to http://localhost:3000 if neither is set.
NEXT_PUBLIC_SITE_URL=                 # [REQUIRED for production] e.g. https://your-app.vercel.app

# ─── Anthropic (AI Agents) ────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=                    # [REQUIRED] for agent orchestrator

# ─── Engine ────────────────────────────────────────────────────────────────
ENGINE_URL=http://localhost:8000             # quant engine base URL
ENGINE_API_KEY=                              # [REQUIRED] internal API key for web → engine (generate a random secret)

# ─── Agents ────────────────────────────────────────────────────────────────
AGENTS_URL=http://localhost:3001             # agent orchestrator base URL
AGENTS_API_KEY=                              # [OPTIONAL] API key for web → agents auth
AGENTS_PORT=3001                             # local agents server port
WEB_URL=http://localhost:3000                # allowed browser origin for local agents CORS

# ─── GitHub Ops Commander ─────────────────────────────────────────────────
# Get from: https://github.com/settings/tokens → Fine-grained or Classic PAT
# Required scopes: repo, security_events, read:org
GITHUB_TOKEN=                                 # [OPTIONAL] PAT for automated ops script
GITHUB_REPO=stevenschling13/sentinel-trading-platform  # owner/repo slug

# ─── Plaid (Portfolio Linking & Bank Account) ────────────────────────
# Get from: https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=                         # [OPTIONAL] Plaid client ID
PLAID_SECRET=                            # [OPTIONAL] Plaid secret key
PLAID_ENV=sandbox                        # [OPTIONAL] sandbox | development | production

# ─── Alpaca Broker API (Account Creation, KYC, Funding) ──────────────
# Get from: https://app.alpaca.markets/brokerage/dashboard/overview
ALPACA_BROKER_API_KEY=                   # [OPTIONAL] Broker API key (not the trading API key)
ALPACA_BROKER_API_SECRET=                # [OPTIONAL] Broker API secret
ALPACA_BROKER_API_URL=https://broker-api.sandbox.alpaca.markets  # sandbox or production

# ─── Auto-Execution Thresholds (Agents) ──────────────────────────────────
# Tune autonomous trade execution. All have safe defaults.
AUTO_EXEC_SIGNAL_THRESHOLD=0.7               # [OPTIONAL] minimum signal strength (0-1) for auto-trade
AUTO_EXEC_DAILY_LIMIT=10                     # [OPTIONAL] max auto-executed trades per day
AUTO_EXEC_MAX_POSITION_VALUE=50000           # [OPTIONAL] max $ value per auto-position

# ─── Agent Runtime Tuning ─────────────────────────────────────────────────
WORKFLOW_JOB_TIMEOUT_SECONDS=300             # [OPTIONAL] workflow job timeout (default 300s)
PYTHON_PATH=python                           # [OPTIONAL] path to Python binary for WAT agent

# ─── Engine Tuning ────────────────────────────────────────────────────────
LOG_LEVEL=INFO                               # [OPTIONAL] engine/gunicorn log level (DEBUG|INFO|WARNING|ERROR)
RATE_LIMIT_PER_MINUTE=100                    # [OPTIONAL] engine API rate limit per IP
POLYGON_API_KEY=                             # [OPTIONAL] Polygon market data API key
ALPACA_API_KEY=                              # [OPTIONAL] Alpaca trading API key
ALPACA_SECRET_KEY=                           # [OPTIONAL] Alpaca trading API secret

# ─── Deployment / CI ──────────────────────────────────────────────────────
RAILWAY_API_TOKEN=                           # [OPTIONAL] Railway deploy token (CI/CD only)

# ─── Observability (OPTIONAL) ─────────────────────────────────────────────
# Sentry error monitoring — get DSN from https://sentry.io
SENTRY_DSN=                                  # [OPTIONAL]

# ─── Notifications (OPTIONAL) ─────────────────────────────────────────────
# Resend email service — get key from https://resend.com
RESEND_API_KEY=                              # [OPTIONAL]
NOTIFICATION_EMAIL=                          # [OPTIONAL] recipient email for agent notifications
