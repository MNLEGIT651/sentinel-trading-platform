# ─── Sentinel Trading Platform ─── Environment Variables ───────────────────
# Copy this file to .env and fill in your credentials.
# Required variables are marked with [REQUIRED]. Optional ones with [OPTIONAL].

# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=             # [REQUIRED] e.g. https://abc123.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # [REQUIRED] public anon key
SUPABASE_URL=                         # [REQUIRED] same project URL, server-side for engine/agents
SUPABASE_SERVICE_ROLE_KEY=            # [REQUIRED] service role key (never expose client-side)
SUPABASE_JWT_SECRET=                  # [REQUIRED for agents auth] JWT secret from Supabase Dashboard → Settings → API

# ─── Anthropic (AI Agents) ────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=                    # [REQUIRED] for agent orchestrator

# ─── Engine ────────────────────────────────────────────────────────────────
ENGINE_URL=http://localhost:8000             # quant engine base URL
ENGINE_API_KEY=                              # [REQUIRED] internal API key for web → engine (generate a random secret)

# ─── Agents ────────────────────────────────────────────────────────────────
AGENTS_URL=http://localhost:3001             # agent orchestrator base URL
AGENTS_PORT=3001                             # local agents server port
WEB_URL=http://localhost:3000                # allowed browser origin for local agents CORS

# ─── GitHub Ops Commander ─────────────────────────────────────────────────
# Get from: https://github.com/settings/tokens → Fine-grained or Classic PAT
# Required scopes: repo, security_events, read:org
GITHUB_TOKEN=                                 # [OPTIONAL] PAT for automated ops script
GITHUB_REPO=stevenschling13/sentinel-trading-platform  # owner/repo slug

# ─── Plaid (Portfolio Linking & Bank Account) ────────────────────────
# Get from: https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=                         # [OPTIONAL] Plaid client ID
PLAID_SECRET=                            # [OPTIONAL] Plaid secret key
PLAID_ENV=sandbox                        # [OPTIONAL] sandbox | development | production

# ─── Observability (OPTIONAL) ─────────────────────────────────────────────
# Sentry error monitoring — get DSN from https://sentry.io
SENTRY_DSN=                                  # [OPTIONAL]

# ─── Notifications (OPTIONAL) ─────────────────────────────────────────────
# Resend email service — get key from https://resend.com
RESEND_API_KEY=                              # [OPTIONAL]
NOTIFICATION_EMAIL=                          # [OPTIONAL] recipient email for agent notifications
