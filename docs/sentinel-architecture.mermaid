%%{ init: { "theme": "base", "themeVariables": { "primaryColor": "#1e293b", "primaryTextColor": "#f8fafc", "primaryBorderColor": "#475569", "lineColor": "#64748b", "secondaryColor": "#0f172a", "tertiaryColor": "#334155" } } }%%

graph TB
    %% ── Client ─────────────────────────────────────────────────────
    Browser["🌐 Browser"]

    %% ── Vercel ─────────────────────────────────────────────────────
    subgraph VERCEL["☁️  Vercel — Public Origin"]
        direction TB
        subgraph CLIENT_BUNDLE["Client Bundle (React 19 + Zustand)"]
            direction LR
            Pages["Pages<br/><small>Dashboard · Markets · Portfolio<br/>Strategies · Signals · Backtest · Agents</small>"]
            HealthHook["useServiceHealth<br/><small>polls /api/engine/health<br/>+ /api/agents/health<br/>every 15s</small>"]
            EngineFetch["engineUrl( )<br/><small>resolves to /api/engine/*</small>"]
            SupabaseRT["useRealtime<br/><small>Supabase client<br/>anon key</small>"]
        end

        subgraph SERVER_ROUTES["Next.js Server-Side Route Handlers"]
            direction LR
            EngineProxy["/api/engine/[...path]<br/><small>proxyServiceRequest('engine')</small>"]
            AgentsProxy["/api/agents/[...path]<br/><small>proxyServiceRequest('agents')</small>"]
            HealthAPI["/api/health<br/>/api/settings/status"]
        end

        ServiceConfig["service-config.ts<br/><small>URL resolution · Auth headers<br/>Timeouts · Retry policy<br/>Localhost rejection in prod</small>"]
    end

    %% ── Railway Engine ─────────────────────────────────────────────
    subgraph RAILWAY_ENGINE["🚂  Railway — Engine (Private)"]
        direction TB
        FastAPI["FastAPI :8000<br/><small>Sentinel Engine v0.1</small>"]
        AuthMW["ApiKeyMiddleware<br/><small>X-API-Key or Bearer token<br/>Public: /health /docs</small>"]
        subgraph ENGINE_ROUTES["Engine API Routes (/api/v1)"]
            direction LR
            DataRoute["/data<br/><small>quotes · bars · history</small>"]
            StratRoute["/strategies<br/><small>scan · signals</small>"]
            BacktestRoute["/backtest<br/><small>run · results</small>"]
            PortfolioRoute["/portfolio<br/><small>orders · positions</small>"]
            RiskRoute["/risk<br/><small>limits · exposure</small>"]
        end
        EngineHealth["/health → 200"]
    end

    %% ── Railway Agents ─────────────────────────────────────────────
    subgraph RAILWAY_AGENTS["🚂  Railway — Agents (Private, Required)"]
        direction TB
        Express["Express :3001<br/><small>Agent Orchestrator v1.0</small>"]
        subgraph AGENTS_DETAIL["Orchestrator"]
            direction LR
            MarketSentinel["🛰 Market<br/>Sentinel"]
            StrategyAnalyst["📊 Strategy<br/>Analyst"]
            RiskMonitor["🛡 Risk<br/>Monitor"]
            Research["🔬 Research"]
            ExecMonitor["⚡ Execution<br/>Monitor"]
        end
        Scheduler["Cron Scheduler<br/><small>15 min · NYSE hours</small>"]
        AgentEndpoints["GET /health /status /alerts<br/>POST /cycle /halt /resume"]
    end

    %% ── External Services ──────────────────────────────────────────
    subgraph EXTERNAL["External Services"]
        direction LR
        Supabase[("🗄️ Supabase<br/><small>PostgreSQL + RLS<br/>Realtime · PostgREST</small>")]
        Polygon["📈 Polygon.io<br/><small>Market data<br/>Quotes · Bars · Tickers</small>"]
        Alpaca["🦙 Alpaca<br/><small>Brokerage<br/>Paper / Live</small>"]
        Anthropic["🤖 Anthropic<br/><small>Claude LLM<br/>Agent reasoning</small>"]
    end

    %% ── Data Flow ──────────────────────────────────────────────────

    %% Browser → Vercel (client-side)
    Browser -->|"HTTPS"| Pages
    Browser -->|"HTTPS"| HealthHook

    %% Client bundle → Server routes (same-origin fetch)
    Pages -->|"fetch via engineUrl( )"| EngineProxy
    Pages -->|"fetch /api/agents/*"| AgentsProxy
    HealthHook -->|"/api/engine/health"| EngineProxy
    HealthHook -->|"/api/agents/health"| AgentsProxy

    %% Client → Supabase (direct, anon key)
    SupabaseRT -.->|"WSS · anon key<br/>(client-side)"| Supabase

    %% Server routes → Service config
    EngineProxy --- ServiceConfig
    AgentsProxy --- ServiceConfig

    %% Server routes → Railway (server-side only)
    EngineProxy ==>|"ENGINE_URL<br/>+ X-API-Key / Bearer<br/><small>Timeouts: 4s–70s</small>"| FastAPI
    AgentsProxy ==>|"AGENTS_URL<br/><small>Timeouts: 6s–8s</small>"| Express

    %% Engine internal
    FastAPI --- AuthMW
    AuthMW --- ENGINE_ROUTES
    FastAPI --- EngineHealth

    %% Agents internal
    Express --- AGENTS_DETAIL
    Express --- Scheduler
    Express --- AgentEndpoints

    %% Engine → External
    DataRoute -->|"REST API"| Polygon
    PortfolioRoute -->|"REST API"| Alpaca
    FastAPI -->|"PostgREST<br/>service_role_key"| Supabase

    %% Agents → External
    Express -->|"EngineClient<br/>server-side SDK"| FastAPI
    Express -->|"service_role_key"| Supabase
    AGENTS_DETAIL -->|"Anthropic SDK<br/>claude-sonnet"| Anthropic

    %% ── Styles ─────────────────────────────────────────────────────
    classDef vercelBox fill:#0070f3,stroke:#0070f3,color:#fff
    classDef railwayBox fill:#7c3aed,stroke:#7c3aed,color:#fff
    classDef externalBox fill:#059669,stroke:#059669,color:#fff
    classDef clientBox fill:#1e40af,stroke:#1e40af,color:#fff
    classDef browserNode fill:#f59e0b,stroke:#d97706,color:#1e293b

    class Browser browserNode
    class Pages,HealthHook,EngineFetch,SupabaseRT clientBox
    class EngineProxy,AgentsProxy,HealthAPI,ServiceConfig vercelBox
    class FastAPI,AuthMW,DataRoute,StratRoute,BacktestRoute,PortfolioRoute,RiskRoute,EngineHealth railwayBox
    class Express,MarketSentinel,StrategyAnalyst,RiskMonitor,Research,ExecMonitor,Scheduler,AgentEndpoints railwayBox
    class Supabase,Polygon,Alpaca,Anthropic externalBox
