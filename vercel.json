{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "turbo run build --filter=@sentinel/web",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/web/ packages/shared/",
  "regions": ["iad1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  }
}
