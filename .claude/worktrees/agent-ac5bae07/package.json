{
  "name": "sentinel",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:web": "pnpm --filter @sentinel/web test",
    "test:web:e2e": "pnpm --filter @sentinel/web test:e2e",
    "test:agents": "pnpm --filter @sentinel/agents test",
    "test:engine": "node scripts/engine-python.mjs -m pytest tests --tb=short",
    "lint": "turbo lint",
    "lint:engine": "node scripts/engine-python.mjs -m ruff check src tests",
    "format:check:engine": "node scripts/engine-python.mjs -m ruff format --check src tests",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "pnpm --filter web exec eslint --fix --max-warnings=0"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ],
    "apps/engine/**/*.py": [
      "node scripts/engine-python.mjs -m ruff check --fix --exit-zero",
      "node scripts/engine-python.mjs -m ruff format"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "flatted": ">=3.4.2"
    }
  }
}
