{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@sentinel/web", "dev"],
      "port": 3000
    },
    {
      "name": "agents",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@sentinel/agents", "dev"],
      "port": 3001
    },
    {
      "name": "engine",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "scripts/engine-python.mjs",
        "-m",
        "uvicorn",
        "src.api.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "port": 8000
    },
    {
      "name": "codex",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "Codex", "dev"],
      "port": 3200
    }
  ]
}
