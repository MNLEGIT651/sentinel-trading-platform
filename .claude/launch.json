{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Web Dashboard",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "pnpm", "--filter", "@sentinel/web", "dev"],
      "port": 3000
    },
    {
      "name": "Quant Engine",
      "runtimeExecutable": "cmd",
      "runtimeArgs": [
        "/c",
        "cd",
        "apps\\engine",
        "&&",
        "uv",
        "run",
        "python",
        "-m",
        "uvicorn",
        "src.api.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "port": 8000
    },
    {
      "name": "Agents (stub)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "pnpm", "--filter", "@sentinel/agents", "dev"],
      "port": 3001
    }
  ]
}
